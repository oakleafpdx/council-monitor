# Council Meeting Monitor — Local Configuration
# Copy this file to .env and fill in your keys.

# AssemblyAI — https://www.assemblyai.com/dashboard
ASSEMBLYAI_API_KEY=your_key_here

# YouTube Data API v3 — Google Cloud Console → APIs & Services → Credentials
YOUTUBE_API_KEY=your_key_here

# GitHub Personal Access Token (needs "repo" scope)
# Create at: https://github.com/settings/tokens → Generate new token (classic)
GITHUB_PAT=your_token_here

# Your GitHub repo in format: username/repo-name
GITHUB_REPO=your_username/council-monitor
